{
	"name": "vite-plugin-react-native-web",
	"version": "3.0.0-rc.2",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"description": "React Native Web support for Vite",
	"license": "MIT",
	"repository": {
		"url": "git+https://github.com/Bram-dc/vite-plugin-react-native-web.git"
	},
	"author": "Bram del Canho",
	"homepage": "https://github.com/Bram-dc/vite-plugin-react-native-web#readme",
	"bugs": "https://github.com/Bram-dc/vite-plugin-react-native-web/issues",
	"main": "./dist/cjs/index.js",
	"module": "./dist/es/index.js",
	"exports": {
		"types": "./types/index.d.ts",
		"import": "./dist/es/index.js",
		"default": "./dist/cjs/index.js"
	},
	"engines": {
		"node": ">=14.0.0"
	},
	"scripts": {
		"build": "rolldown -c rolldown.config.ts",
		"prerelease": "npm run build",
		"release": "npm publish"
	},
	"files": [
		"dist",
		"!dist/**/*.map",
		"types",
		"README.md"
	],
	"keywords": [
		"vite",
		"vite-plugin",
		"plugin",
		"react-native",
		"react-native-web"
	],
	"dependencies": {
		"flow-remove-types": "^2.304.0"
	},
	"devDependencies": {
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^25.5.0",
		"rolldown": "^1.0.0-rc.9",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0"
	},
	"types": "./types/index.d.ts"
}
